class Solution {
    public int findCircleNum(int[][] isConnected) {                         //ADJ MATRIX  
        int n = isConnected.length;
        boolean visit[] = new boolean[n];
        int count = 0;
        for(int i=0;i<n;i++)
        {
            if(!visit[i])
            {
                count++;
                dfs(isConnected , visit , i);
            }
        }
        return count;
    }
    private void dfs(int[][] graph,boolean[] visit,int city)
    {
        visit[city] = true;
        for(int neighbour=0;neighbour<graph.length;neighbour++)
        {
            // If connected and not visited
            if(graph[city][neighbour]==1 && !visit[neighbour])  
            {
                dfs(graph,visit,neighbour);
            }
        }
    }
}
